{
	"[csv]": {
		"editor.inlayHints.maximumLength": 0
	},
	"[dockercompose]": {
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.insertSpaces": true,
		"editor.quickSuggestions": {
			"comments": false,
			"other": true,
			"strings": true
		},
		"editor.tabSize": 2
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[go]": {
		"editor.defaultFormatter": "golang.go"
	},
	"[markdown]": {
		"cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
		"cSpell.advanced.feature.useReferenceProviderWithRename": true,
		"cSpell.fixSpellingWithRenameProvider": true,
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.formatOnSave": false,
		"editor.quickSuggestions": {
			"comments": "off",
			"other": "off",
			"strings": "off"
		},
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"editor.wordWrap": "on"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true
	},
	"[search-result]": {
		"editor.lineNumbers": "on"
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"amp.dangerouslyAllowAll": true,
	"bicep.enableSurveys": false,
	"chat.agent.maxRequests": 100,
	"chat.editor.fontFamily": "Monaspace Neon",
	"chat.fontFamily": "Monaspace Neon",
	"chat.instructionsFilesLocations": {
		".github/instructions": true,
		"${userHome}/.aitk/instructions/": true
	},
	"chat.mcp.discovery.enabled": {
		"claude-desktop": true,
		"cursor-global": true,
		"cursor-workspace": true,
		"windsurf": true
	},
	"chat.mcp.gallery.enabled": true,
	"chat.useAgentSkills": true,
	"chat.viewSessions.orientation": "stacked",
	"cSpell.ignorePaths": [
		"package-lock.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".zsh_history"
	],
	"debug.console.fontFamily": "Monaspace Neon",
	"diffEditor.codeLens": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.renderSideBySide": false,
	"docker.extension.dockerEngineAvailabilityPrompt": false,
	"docker.extension.enableComposeLanguageServer": false,
	"editor.accessibilitySupport": "off",
	"editor.codeLensFontFamily": "Geist Mono",
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.fontFamily": "Monaspace Neon",
	"editor.fontSize": 11,
	"editor.fontWeight": "350",
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"editor.inlayHints.fontFamily": "Monaspace Neon",
	"editor.inlineSuggest.enabled": true,
	"editor.inlineSuggest.fontFamily": "Monaspace Neon",
	"editor.inlineSuggest.suppressSuggestions": true,
	"editor.largeFileOptimizations": true,
	"editor.lineHeight": 2,
	"editor.linkedEditing": true,
	"editor.suggest.showWords": false,
	"editor.suggestSelection": "first",
	"editor.tabSize": 2,
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"*.cts": "${capture}.typegen.ts",
		"*.mts": "${capture}.typegen.ts",
		"*.ts": "${capture}.typegen.ts",
		"*.tsx": "${capture}.typegen.ts",
		"Cargo.toml": "Cargo.lock"
	},
	"git.autofetch": true,
	"git.blame.editorDecoration.enabled": true,
	"git.blame.statusBarItem.enabled": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.openRepositoryInParentFolders": "always",
	"git.path": "/usr/bin/git",
	"github.copilot.chat.codesearch.enabled": true,
	"github.copilot.selectedCompletionModel": "",
	"githubPullRequests.fileListLayout": "tree",
	"githubPullRequests.pullBranch": "always",
	"githubPullRequests.pushBranch": "always",
	"go.toolsManagement.autoUpdate": true,
	"javascript.preferences.quoteStyle": "single",
	"makefile.configureOnOpen": true,
	"markdown.preview.fontFamily": "Monaspace Neon",
	"nightwatch.quickSettings.parallels": 10,
	"python.analysis.autoImportCompletions": true,
	"python.analysis.completeFunctionParens": true,
	"python.analysis.languageServerMode": "full",
	"python.defaultInterpreterPath": "/usr/local/bin/python3",
	"python.experiments.enabled": false,
	"python.languageServer": "Pylance",
	"python.terminal.activateEnvInCurrentTerminal": true,
	"python.venvPath": "${workspaceFolder}/.venv",
	"redhat.telemetry.enabled": false,
	"remote.defaultExtensionsIfInstalledLocally": [
		"GitHub.copilot",
		"GitHub.copilot-chat",
		"GitHub.vscode-pull-request-github"
	],
	"scm.defaultViewMode": "tree",
	"scss.showErrors": true,
	"search.defaultViewMode": "tree",
	"security.promptForLocalFileProtocolHandling": false,
	"security.workspace.trust.untrustedFiles": "open",
	"svelte.enable-ts-plugin": true,
	"terminal.integrated.defaultProfile.osx": "zsh",
	"terminal.integrated.env.osx": {
		"CW_NEW_SESSION": "1",
		"Q_NEW_SESSION": "1"
	},
	"terminal.integrated.fontFamily": "Monaspace Neon",
	"terminal.integrated.fontSize": 12,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"vs-kubernetes": {
		"vscode-kubernetes.helm-path-mac": "${userHome}/.vs-kubernetes/tools/helm/darwin-arm64/helm",
		"vscode-kubernetes.minikube-path-mac": "${userHome}/.vs-kubernetes/tools/minikube/darwin-arm64/minikube"
	},
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
	"vsintellicode.python.completionsEnabled": true,
	"window.commandCenter": true,
	"window.newWindowDimensions": "inherit",
	"workbench.colorTheme": "Ayu Mirage",
	"workbench.commandPalette.experimental.suggestCommands": true,
	"workbench.editor.enablePreview": false,
	"workbench.externalBrowser": "chrome",
	"workbench.panel.showLabels": false,
	"workbench.sideBar.location": "right",
	"typescript.tsserver.enableTracing": true,
	"typescript.tsserver.experimental.enableProjectDiagnostics": true,
	"typescript.tsserver.maxTsServerMemory": 16000,
	"github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
	"typescript.tsserver.log": "verbose",
	"geminicodeassist.displayInlineContextHint": false,
	"http.systemCertificatesNode": true
}