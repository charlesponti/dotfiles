[include]
    # When this file is stowed the actual location of the
    # base/local files is inside the stow package itself.
    # Use paths that exist after stow runs so Git can load them.
    path = ~/.dotfiles/stow/git/.gitconfig.base
    path = ~/.dotfiles/stow/git/.gitconfig.local

[user]
	name = Charles Ponti
	email = 1757624+charlesponti@users.noreply.github.com
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
