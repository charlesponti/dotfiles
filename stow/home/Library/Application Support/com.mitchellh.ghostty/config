# ---------------------------------------------------------
# Ghostty Configuration File
# ---------------------------------------------------------

# --- Fonts & Text ---
font-family = "LigaSFMonoNerdFont"
font-size = 12
# Adjust-cell-height is additive; 15% adds extra breathing room
adjust-cell-height = 15%
# Allows Option+Click to move cursor (Requires Shell Integration)
cursor-click-to-move = true

# --- Colors & Aesthetics ---
# Hex values must be quoted or prefixed with #
background = "#111111"
foreground = "#d0d0d0"
cursor-color = "#b0b0b0"
selection-background = "#3a3a3a"
selection-foreground = "#e6e6e6"

background-opacity = 0.92
# Smooths out background transparency on supported systems
background-blur = true

# --- Window & macOS UI ---
window-padding-x = 12
window-padding-y = 10
macos-titlebar-style = transparent
macos-window-shadow = true
# Keeps your tabs and splits exactly where you left them
window-save-state = always

# --- Cursor & Interactivity ---
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
# Protects against "pastejacking" (malicious hidden commands)
clipboard-paste-protection = true
copy-on-select = true

# --- Terminal Behavior ---
scrollback-limit = 20000
# Automatically handles terminfo when SSHing into remote servers
shell-integration-features = cursor,sudo,ssh-terminfo

# --- Power User Features ---

# 1. Quick Terminal (Quake-style toggle)
# Access your terminal from anywhere with Cmd + `
keybind = global:cmd+shift+enter=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-animation-duration = 0.2

# 2. Window Management Chords (Leader Key: Ctrl+A)
# Mimics Tmux behavior without needing Tmux installed
keybind = ctrl+a>n=new_window
keybind = ctrl+a>s=new_split:right
keybind = ctrl+a>v=new_split:down
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>j=goto_split:down

# 3. Focus Follows Mouse
# Switch active split panes just by hovering
focus-follows-mouse = true

custom-shader = "/Users/charlesponti/Library/Application Support/com.mitchellh.ghostty/shader.glsl"