{
	"[csv]": {
		"editor.inlayHints.maximumLength": 0
	},
	"[dockercompose]": {
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.insertSpaces": true,
		"editor.quickSuggestions": {
			"comments": false,
			"other": true,
			"strings": true
		},
		"editor.tabSize": 2
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[go]": {
		"editor.defaultFormatter": "golang.go"
	},
	"[markdown]": {
		"cSpell.advanced.feature.useReferenceProviderRemove": "/^#+\\s/",
		"cSpell.advanced.feature.useReferenceProviderWithRename": true,
		"cSpell.fixSpellingWithRenameProvider": true,
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.fontSize": 15,
		"editor.formatOnSave": false,
		"editor.quickSuggestions": {
			"comments": "off",
			"other": "off",
			"strings": "off"
		},
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"editor.wordWrap": "on"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true
	},
	"[search-result]": {
		"editor.lineNumbers": "on"
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"bicep.enableSurveys": false,
	"chat.agent.maxRequests": 100,
	"chat.editor.fontFamily": "SF Mono",
	"chat.fontFamily": "SF Mono",
	"chat.instructionsFilesLocations": {
		".github/instructions": true,
		"~/.aitk/instructions/": true
	},
	"chat.mcp.discovery.enabled": {
		"claude-desktop": true,
		"cursor-global": true,
		"cursor-workspace": true,
		"windsurf": true
	},
	"chat.mcp.gallery.enabled": true,
	"chat.tools.terminal.autoApprove": {
		"basename": true,
		"bun": true,
		"cat": true,
		"cd": true,
		"chmod": false,
		"chown": false,
		"cmp": true,
		"column": true,
		"curl": false,
		"cut": true,
		"date": true,
		"dd": false,
		"del": false,
		"df": true,
		"dirname": true,
		"du": true,
		"echo": true,
		"erase": false,
		"eval": false,
		"file": true,
		"find": true,
		"findstr": true,
		"Get-ChildItem": true,
		"Get-Content": true,
		"Get-Date": true,
		"Get-Location": true,
		"Get-Random": true,
		"git": true,
		"grep": true,
		"head": true,
		"iex": false,
		"Invoke-Expression": false,
		"Invoke-RestMethod": false,
		"Invoke-WebRequest": false,
		"irm": false,
		"iwr": false,
		"Join-Path": true,
		"jq": false,
		"kill": false,
		"ls": true,
		"nl": true,
		"Out-String": true,
		"ps": false,
		"pwd": true,
		"rd": false,
		"readlink": true,
		"realpath": true,
		"Remove-Item": false,
		"rg": true,
		"ri": false,
		"rm": false,
		"rmdir": false,
		"sed": true,
		"Set-Acl": false,
		"Set-ItemProperty": false,
		"sleep": true,
		"sort": true,
		"sp": false,
		"Split-Path": true,
		"spps": false,
		"Start-Sleep": true,
		"stat": true,
		"Stop-Process": false,
		"tail": true,
		"taskkill": false,
		"taskkill.exe": false,
		"top": false,
		"tr": true,
		"tree": true,
		"wc": true,
		"wget": false,
		"Where-Object": true,
		"which": true,
		"Write-Host": true,
		"Write-Output": true,
		"xargs": false
	},
	"chat.tools.urls.autoApprove": {
		"https://*.wikipedia.org/*": true,
		"https://github.com/*": true,
		"https://opencode.ai": {
			"approveRequest": false,
			"approveResponse": true
		}
	},
	"chat.useAgentSkills": true,
	"chat.viewSessions.orientation": "stacked",
	"cSpell.ignorePaths": [
		"package-lock.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".zsh_history"
	],
	"cSpell.userWords": [
		"Amaro",
		"Aponte",
		"bunx",
		"Celso",
		"hackefeller",
		"OLLAMA",
		"Pagán",
		"Ponti",
		"Rican"
	],
	"debug.console.fontFamily": "SF Mono",
	"diffEditor.codeLens": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.renderSideBySide": false,
	"docker.extension.dockerEngineAvailabilityPrompt": false,
	"docker.extension.enableComposeLanguageServer": false,
	"editor.accessibilitySupport": "off",
	"editor.codeLensFontFamily": "SF Mono",
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.fontFamily": "SF Mono",
	"editor.fontSize": 13,
	"editor.fontWeight": "350",
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"editor.inlayHints.fontFamily": "SF Mono",
	"editor.inlineSuggest.enabled": true,
	"editor.inlineSuggest.experimental.showOnSuggestConflict": "always",
	"editor.inlineSuggest.fontFamily": "SF Mono",
	"editor.largeFileOptimizations": true,
	"editor.lineHeight": 2,
	"editor.linkedEditing": true,
	"editor.suggest.showWords": false,
	"editor.suggestSelection": "first",
	"editor.tabSize": 2,
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"*.cts": "${capture}.typegen.ts",
		"*.mts": "${capture}.typegen.ts",
		"*.ts": "${capture}.typegen.ts",
		"*.tsx": "${capture}.typegen.ts",
		"Cargo.toml": "Cargo.lock"
	},

		"git.autofetch": true,
	"git.blame.editorDecoration.enabled": true,
	"git.blame.statusBarItem.enabled": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.openRepositoryInParentFolders": "always",
	"git.path": "/usr/bin/git",
	"githubPullRequests.assignCreated": "${user}",
	"githubPullRequests.fileListLayout": "tree",
	"githubPullRequests.pullBranch": "always",
		"githubPullRequests.pullRequestDescription": "template",
	"githubPullRequests.pushBranch": "always",
	"gitlens.blame.fontFamily": "SF Mono",
	"gitlens.currentLine.fontFamily": "SF Mono",
	"go.toolsManagement.autoUpdate": true,
	"http.systemCertificatesNode": true,
	"javascript.preferences.quoteStyle": "single",
	"javascript.updateImportsOnFileMove.enabled": "always",
		"json.schemaDownload.trustedDomains": {
			"https://schemastore.azurewebsites.net/": true,
			"https://raw.githubusercontent.com/": true,
			"https://www.schemastore.org/": true,
			"https://json.schemastore.org/": true,
			"https://json-schema.org/": true,
			"https://models.dev/": true,
			"https://opencode.ai/config.json": true
		},
	"makefile.configureOnOpen": true,
	"markdown.preview.fontFamily": "SF Mono",
	"nightwatch.quickSettings.parallels": 10,
	"pgsql.serverGroups": [
		{
			"id": "12D3B4D3-DC16-4D56-BE8D-65FF99D6C1D6",
			"isDefault": true,
			"name": "Servers"
		}
	],
	"python.analysis.autoImportCompletions": true,
	"python.analysis.completeFunctionParens": true,
	"python.analysis.languageServerMode": "full",
	"python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
	"python.experiments.enabled": false,
	"python.languageServer": "Pylance",
	"python.terminal.activateEnvInCurrentTerminal": true,
	"python.venvPath": "${workspaceFolder}/.venv",
	"redhat.telemetry.enabled": false,
		"remote.defaultExtensionsIfInstalledLocally": ["GitHub.vscode-pull-request-github"],
	"scm.defaultViewMode": "tree",
	"scss.showErrors": true,
	"search.defaultViewMode": "tree",
	"security.promptForLocalFileProtocolHandling": false,
	"security.workspace.trust.untrustedFiles": "open",
	"svelte.enable-ts-plugin": true,
	"terminal.integrated.env.osx": {
		"CW_NEW_SESSION": "1",
		"Q_NEW_SESSION": "1"
	},
	"terminal.integrated.fontFamily": "SF Mono",
	"terminal.integrated.fontLigatures.enabled": true,
	"terminal.integrated.fontSize": 12,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
	"vsintellicode.python.completionsEnabled": true,
	"window.commandCenter": true,
	"window.newWindowDimensions": "inherit",
	"workbench.commandPalette.experimental.suggestCommands": true,
	"workbench.editor.enablePreview": false,
	"workbench.externalBrowser": "chrome",
	"workbench.panel.showLabels": false,
	"workbench.sideBar.location": "left",
	"vs-kubernetes": {
		"vs-kubernetes.suppress-helm-not-found-alerts": true
	},
	"C_Cpp.default.compilerPath": "/usr/bin/gcc",
	"chat.editing.confirmEditRequestRemoval": false,
	"terminal.integrated.tabs.location": "left"
}
