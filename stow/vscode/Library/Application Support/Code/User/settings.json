{
    "workbench.colorTheme": "Ayu Mirage Bordered",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "git.path": "/usr/bin/git",
    "python.defaultInterpreterPath": "",
    "python.venvPath": "${workspaceFolder}/.venv",
    "C_Cpp.default.compilerPath": "/usr/bin/gcc",
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "chat.tools.global.autoApprove": true,
    "makefile.configureOnOpen": true,
    "explorer.confirmDelete": false,
    "workbench.secondarySideBar.showLabels": false,
    "docker.extension.enableComposeLanguageServer": false,
    "editor.accessibilitySupport": "off",
    "workbench.iconTheme": "ayu",
    "svelte.enable-ts-plugin": true,
    "git.autofetch": true,
    "editor.fontFamily": "SF Mono",
    "editor.codeLensFontFamily": "SF Mono",
    "editor.inlayHints.fontFamily": "SF Mono",
    "editor.inlineSuggest.fontFamily": "SF Mono",
    "chat.editor.fontFamily": "SF Mono",
    "chat.fontFamily": "SF Compact",
    "debug.console.fontFamily": "SF Mono",
    "scm.inputFontFamily": "SF Compact",
    "terminal.integrated.fontFamily": "SF Mono",
    "notebook.markup.fontFamily": "SF Mono",
    "gitlens.currentLine.fontFamily": "SF Mono",
    "gitlens.blame.fontFamily": "SF Mono",
    "markdown.preview.fontFamily": "SF Mono",
    "workbench.activityBar.location": "bottom",
    "workbench.browser.enableChatTools": true,
    "workbench.browser.openLocalhostLinks": true,
    "chat.viewSessions.orientation": "stacked"
}